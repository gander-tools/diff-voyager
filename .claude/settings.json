{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowedTools": ["Skill"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run-biome.sh",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
