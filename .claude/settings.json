{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowedTools": ["Skill"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx -y @biomejs/biome format --write .",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
