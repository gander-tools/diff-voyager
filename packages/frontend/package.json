{
	"name": "@gander-tools/diff-voyager-frontend",
	"version": "0.1.18",
	"description": "Vue.js frontend for Diff Voyager",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "vite build",
		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage --passWithNoTests",
		"type-check": "vue-tsc --build",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"keywords": [
		"diff-voyager",
		"frontend",
		"vue"
	],
	"author": "Adam Gąsowski (https://github.com/gander)",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gander-tools/diff-voyager.git",
		"directory": "packages/frontend"
	},
	"bugs": {
		"url": "https://github.com/gander-tools/diff-voyager/issues"
	},
	"homepage": "https://github.com/gander-tools/diff-voyager#readme",
	"engines": {
		"node": "^22.0.0 || ^24.0.0",
		"npm": "^10.0.0 || ^11.0.0"
	},
	"dependencies": {
		"@gander-tools/diff-voyager-shared": "*",
		"@ts-rest/core": "^3.52.1",
		"@vee-validate/zod": "^4.15.1",
		"@vicons/tabler": "^0.13.0",
		"@vitest/ui": "^4.0.16",
		"@vueuse/core": "^14.1.0",
		"date-fns": "^4.1.0",
		"msw": "^2.12.7",
		"naive-ui": "^2.43.2",
		"ofetch": "^1.5.1",
		"pinia": "^3.0.4",
		"vee-validate": "^4.15.1",
		"vue": "^3.5.26",
		"vue-i18n": "^11.2.8",
		"vue-router": "^4.6.4",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@playwright/test": "^1.57.0",
		"@tsconfig/node24": "^24.0.3",
		"@types/jsdom": "^27.0.0",
		"@types/node": "^24.10.4",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitest/coverage-v8": "^4.0.0",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"jsdom": "^27.4.0",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.9.3",
		"vite": "beta",
		"vite-plugin-vue-devtools": "^8.0.5",
		"vitest": "^4.0.16",
		"vue-tsc": "^3.2.2"
	}
}
