{
	"name": "@gander-tools/diff-voyager-backend",
	"version": "0.1.23",
	"type": "module",
	"description": "Backend crawler and API for Diff Voyager",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"keywords": [
		"diff-voyager",
		"backend",
		"crawler",
		"api"
	],
	"author": "Adam Gąsowski (https://github.com/gander)",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gander-tools/diff-voyager.git",
		"directory": "packages/backend"
	},
	"bugs": {
		"url": "https://github.com/gander-tools/diff-voyager/issues"
	},
	"homepage": "https://github.com/gander-tools/diff-voyager#readme",
	"engines": {
		"node": "^22.0.0 || ^24.0.0",
		"npm": "^10.0.0 || ^11.0.0"
	},
	"dependencies": {
		"@fastify/cors": "^9.0.1",
		"@fastify/rate-limit": "^9.1.0",
		"@fastify/swagger": "^8.15.0",
		"@fastify/swagger-ui": "^5.0.0",
		"@gander-tools/diff-voyager-shared": "*",
		"@ts-rest/fastify": "^3.52.1",
		"better-sqlite3": "^12.0.0",
		"crawlee": "^3.12.3",
		"drizzle-orm": "^0.45.0",
		"fastify": "^4.29.1",
		"pixelmatch": "^7.0.0",
		"playwright": "^1.49.1",
		"pngjs": "^7.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.5",
		"@types/pixelmatch": "^5.2.6",
		"@types/pngjs": "^6.0.5",
		"@types/supertest": "^6.0.2",
		"@types/tmp": "^0.2.6",
		"@vitest/coverage-v8": "^4.0.0",
		"drizzle-kit": "^0.31.0",
		"pino-pretty": "^13.0.0",
		"supertest": "^7.0.0",
		"tmp": "^0.2.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^4.0.0"
	}
}
