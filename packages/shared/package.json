{
	"name": "@gander-tools/diff-voyager-shared",
	"version": "0.1.5",
	"type": "module",
	"description": "Shared TypeScript types and utilities for Diff Voyager",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc --build",
		"watch": "tsc --build --watch",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"keywords": [
		"diff-voyager",
		"types",
		"shared"
	],
	"author": "Adam Gąsowski (https://github.com/gander)",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gander-tools/diff-voyager.git",
		"directory": "packages/shared"
	},
	"bugs": {
		"url": "https://github.com/gander-tools/diff-voyager/issues"
	},
	"homepage": "https://github.com/gander-tools/diff-voyager#readme",
	"engines": {
		"node": "^22.0.0 || ^24.0.0",
		"npm": "^10.0.0 || ^11.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"@vitest/coverage-v8": "^4.0.0",
		"typescript": "^5.7.3",
		"vitest": "^4.0.0"
	},
	"dependencies": {
		"@ts-rest/core": "^3.52.1",
		"zod": "^3.25.76"
	}
}
