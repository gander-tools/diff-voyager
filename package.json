{
  "name": "diff-voyager",
  "description": "Local website version comparison tool for framework migrations - crawl, compare, and verify visual, SEO, and performance changes",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "pnpm install && pnpm run build:shared",
    "build:shared": "pnpm run build --filter=@gander-tools/diff-voyager-shared",
    "build:backend": "pnpm run build --filter=@gander-tools/diff-voyager-backend",
    "build:frontend": "pnpm run build --filter=@gander-tools/diff-voyager-frontend",
    "build": "pnpm run build:shared && pnpm run build:backend && pnpm run build:frontend",
    "dev:backend": "pnpm run dev --filter=@gander-tools/diff-voyager-backend",
    "dev:frontend": "pnpm run dev --filter=@gander-tools/diff-voyager-frontend",
    "test": "pnpm run test --filter='./packages/*'",
    "test:backend": "pnpm run test --filter=@gander-tools/diff-voyager-backend",
    "test:frontend": "pnpm run test --filter=@gander-tools/diff-voyager-frontend",
    "test:shared": "pnpm run test --filter=@gander-tools/diff-voyager-shared",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "pnpm run clean --filter='./packages/*' && rm -rf node_modules"
  },
  "keywords": [
    "diff",
    "visual-regression",
    "seo",
    "performance",
    "crawler",
    "website-comparison",
    "framework-migration",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gander-tools/diff-voyager.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
